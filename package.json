{
  "name": "pulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pulse — un clon funcional de Twitter/X (challenge full-stack)",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1"
  }
}

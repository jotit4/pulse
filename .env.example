# ─────────────────────────────────────────────────────────────
# Pulse — variables de entorno
# Copiá este archivo a `.env` y ajustá los valores.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (connection string completa)
DATABASE_URL=postgresql://pulse:pulse@localhost:5432/pulse

# API
API_PORT=3001
NODE_ENV=development
# Origen permitido para CORS / cookies (el frontend en dev)
WEB_ORIGIN=http://localhost:5173

# Autenticación
# Días de validez de la sesión antes de expirar
SESSION_TTL_DAYS=30
# Nombre de la cookie de sesión
SESSION_COOKIE_NAME=pulse_session

# Frontend (Vite) — debe apuntar a la API
VITE_API_URL=http://localhost:3001

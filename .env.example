# ─────────────────────────────────────────────────────────────
# Pulse — variables de entorno
# Copiá este archivo a `.env` y ajustá los valores.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Connection string completa; en Docker Compose el host es "db" (nombre del servicio).
# Para desarrollo local: postgresql://pulse:pulse@localhost:5432/pulse
DATABASE_URL=postgresql://pulse:pulse@localhost:5432/pulse

# ── API ───────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development
# Origen permitido para CORS / cookies (el frontend en dev o en prod)
WEB_ORIGIN=http://localhost:5173

# ── Autenticación ─────────────────────────────────────────────
# Días de validez de la sesión antes de expirar
SESSION_TTL_DAYS=30
# Nombre de la cookie de sesión httpOnly
SESSION_COOKIE_NAME=pulse_session
# Override del flag Secure de la cookie. Si se omite, se deriva de NODE_ENV
# (Secure sólo en production). Poné "false" para servir la demo por HTTP plano.
# SECURE_COOKIE=false

# ── Frontend (Vite — build time) ──────────────────────────────
# En desarrollo el proxy de Vite redirige /api → :3001; no se usa esta variable.
# En producción (Docker) se pasa como ARG al Dockerfile: VITE_API_BASE=/api
# y nginx proxea /api/ → http://api:3001/ dentro de la red Docker.
VITE_API_BASE=/api

# ── Docker Compose ────────────────────────────────────────────
# Credenciales de la base de datos usadas por el servicio "db" del compose.
# Deben coincidir con la DATABASE_URL de arriba.
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse
POSTGRES_DB=pulse

# Si es "true", el entrypoint de la API ejecuta db:seed al arrancar.
# Útil para la primera vez o demos. En producción real ponerlo en "false".
SEED_ON_START=true
